---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Eze Angeloni">
  <Fragment slot="head">
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;700;800&family=DM+Mono:ital@0;1&family=Cormorant+Garamond:wght@300;400&display=swap" rel="stylesheet" />
    <style>
      *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
      :root {
        --bg: #080810; --text: #f0ede8; --muted: rgba(240,237,232,0.3);
      }
      html, body { width: 100%; height: 100%; overflow: hidden; background: var(--bg); color: var(--text); font-family: 'Syne', sans-serif; cursor: none; }
      canvas { position: fixed; inset: 0; width: 100%; height: 100%; }
      #hero { position: fixed; inset: 0; display: flex; flex-direction: column; align-items: center; justify-content: flex-start; padding-top: 4vh; text-align: center; pointer-events: none; z-index: 10; gap: 8px; }
      #hero h1 { font-size: clamp(3rem,8vw,7rem); font-weight: 800; letter-spacing: -0.03em; opacity: 0; animation: fadeUp 1.2s cubic-bezier(.16,1,.3,1) .3s forwards; }
      #hero p { font-family: 'DM Mono', monospace; font-size: clamp(.7rem,1.5vw,.95rem); letter-spacing: .25em; text-transform: uppercase; color: var(--muted); opacity: 0; animation: fadeUp 1.2s cubic-bezier(.16,1,.3,1) .6s forwards; }
      #hint { position: fixed; bottom: 2rem; left: 50%; transform: translateX(-50%); font-family: 'DM Mono', monospace; font-size: .7rem; letter-spacing: .2em; color: var(--muted); text-transform: uppercase; z-index: 10; pointer-events: none; opacity: 0; animation: fadeUp 1s ease 1.5s forwards; }
      #modal-overlay { position: fixed; inset: 0; background: rgba(8,8,16,0.85); backdrop-filter: blur(12px); z-index: 100; display: flex; align-items: center; justify-content: center; opacity: 0; pointer-events: none; transition: opacity .4s ease; }
      #modal-overlay.open { opacity: 1; pointer-events: all; }
      #modal { background: rgba(240,237,232,0.04); border: 1px solid rgba(240,237,232,0.1); border-radius: 16px; padding: 3rem; max-width: 680px; width: 90%; max-height: 80vh; overflow-y: auto; position: relative; transform: translateY(30px); transition: transform .4s cubic-bezier(.16,1,.3,1); }
      #modal-overlay.open #modal { transform: translateY(0); }
      #modal h2 { font-family: 'Cormorant Garamond', serif; font-size: clamp(2rem,5vw,3.5rem); font-weight: 300; letter-spacing: .3em; text-transform: uppercase; margin-bottom: 1.5rem; }
      #modal p { font-family: 'DM Mono', monospace; font-size: .85rem; line-height: 1.9; color: var(--muted); }
      #modal-close { position: absolute; top: 1.2rem; right: 1.5rem; background: none; border: none; color: var(--muted); font-size: 1.5rem; cursor: pointer; line-height: 1; transition: color .2s; }
      #modal-close:hover { color: var(--text); }
      @keyframes fadeUp { from { opacity:0; transform:translateY(20px); } to { opacity:1; transform:translateY(0); } }
      @keyframes logoGlow {
        0%   { filter: brightness(0) invert(1) drop-shadow(0 0 0px transparent); }
        15%  { filter: brightness(0) invert(1) drop-shadow(0 0 18px #6ef9f5) drop-shadow(0 0 40px #6ef9f580); }
        30%  { filter: brightness(0) invert(1) drop-shadow(0 0 18px #c77dff) drop-shadow(0 0 40px #c77dff80); }
        50%  { filter: brightness(0) invert(1) drop-shadow(0 0 18px #ff6eb4) drop-shadow(0 0 40px #ff6eb480); }
        65%  { filter: brightness(0) invert(1) drop-shadow(0 0 18px #b8f75b) drop-shadow(0 0 40px #b8f75b80); }
        80%  { filter: brightness(0) invert(1) drop-shadow(0 0 18px #ff9f1c) drop-shadow(0 0 40px #ff9f1c80); }
        100% { filter: brightness(0) invert(1) drop-shadow(0 0 0px transparent); }
      }
      #logo { width: clamp(16rem,40vw,30rem); margin-bottom: -8rem; filter: brightness(0) invert(1); animation: fadeUp 1.2s cubic-bezier(.16,1,.3,1) .3s forwards, logoGlow 6s ease-in-out 1.5s infinite; opacity: 0; }
      @media (max-width: 768px) {
        html, body { cursor: auto; }
        #cursor { display: none; }
        #hero { justify-content: center; padding-top: 0; gap: 4px; }
        #logo { width: 72vw; margin-bottom: -5rem; }
        #hero p { font-size: clamp(.75rem,4vw,1rem); letter-spacing: .2em; }
        #hint { font-size: .6rem; bottom: 1.5rem; }
      }
    </style>
  </Fragment>

  <canvas id="canvas"></canvas>
  <div id="hero">
    <img id="logo" src="/eZe.svg" alt="eZe" />
    <p style="font-family: 'Cormorant Garamond', serif; font-size: clamp(1.2rem,3.5vw,2.4rem); font-weight: 300; letter-spacing: .5em; text-transform: uppercase; color: var(--text); opacity: 0; animation: fadeUp 1.2s cubic-bezier(.16,1,.3,1) .5s forwards; padding-left: .5em;">angeloni</p>
    <p>Developer · Builder · Explorer</p>
  </div>
  <div id="hint">explore the circles</div>

  <div id="modal-overlay">
    <div id="modal">
      <button id="modal-close">✕</button>
      <h2>About</h2>
      <p>Hey, I'm Eze. I build things for the web — from the database to the pixel.</p>
      <p style="margin-top:1.2rem">Originally from Argentina, now based in Germany, I've spent years at the intersection of technology and culture. I've helped organize theatre festivals, been part of interdisciplinary collectives, and worked on projects that use culture as a bridge between societies. That background shapes how I approach every line of code — with purpose, context, and people in mind.</p>
      <p style="margin-top:1.2rem">On the technical side, I'm a full-stack developer working with Next.js, React, and Node — building editorial platforms, CMS systems, and interactive experiences.</p>
      <p style="margin-top:1.2rem">Currently available for freelance work. If you've got something interesting brewing, I'd love to hear about it.</p>
    </div>
  </div>

  <script>
    const canvas = document.getElementById('canvas') as HTMLCanvasElement;
    const ctx = canvas.getContext('2d')!;

    let W = canvas.width = window.innerWidth;
    let H = canvas.height = window.innerHeight;
    let mouse = { x: -999, y: -999 };
    const COLORS = ['#ff3f3f','#ff9f1c','#6ef9f5','#b8f75b','#c77dff','#ff6eb4','#38bdf8','#ffd166'];
    const NOTES =  [392, 440, 523, 587, 659, 349, 466, 311];
    let audioCtx: AudioContext | null = null;
    let masterGain: GainNode | null = null;
    let lastSoundTime = 0;
    const SOUND_COOLDOWN = 180;
    function playNote(freq: number) {
      const now = performance.now();
      if (now - lastSoundTime < SOUND_COOLDOWN) return;
      lastSoundTime = now;
      if (!audioCtx) { audioCtx = new AudioContext(); masterGain = audioCtx.createGain(); masterGain.gain.value = 0.18; masterGain.connect(audioCtx.destination); }
      const osc = audioCtx.createOscillator();
      const gain = audioCtx.createGain();
      osc.connect(gain); gain.connect(masterGain!);
      osc.type = 'sine';
      osc.frequency.setValueAtTime(freq, audioCtx.currentTime);
      osc.frequency.exponentialRampToValueAtTime(freq * 0.7, audioCtx.currentTime + 0.25);
      gain.gain.setValueAtTime(1, audioCtx.currentTime);
      gain.gain.exponentialRampToValueAtTime(0.001, audioCtx.currentTime + 0.3);
      osc.start(); osc.stop(audioCtx.currentTime + 0.3);
    }
    let lastHoveredId = -1;
    const SECTIONS: Record<string, () => void> = {
      about: () => openModal()
    };
    const modal = document.getElementById('modal-overlay')!;
    document.getElementById('modal-close')!.addEventListener('click', closeModal);
    modal.addEventListener('click', e => { if(e.target === modal) closeModal(); });
    document.addEventListener('keydown', e => { if(e.key === 'Escape') closeModal(); });
    function openModal(){ modal.classList.add('open'); }
    function closeModal(){ modal.classList.remove('open'); }
    const ABOUT_IDX = 3;
    const LABELS = Array.from({length:41}, (_,i) => i === ABOUT_IDX ? 'about' : '');
    function rnd(a: number, b: number){ return a + Math.random()*(b-a); }

    interface Circle {
      id: number; x: number; y: number; r: number; baseR: number;
      color: string; alpha: number; targetAlpha: number; label: string;
      vx: number; vy: number; delay: number; born: number; phase: number;
    }

    function createCircle(i: number): Circle {
      const r = i === ABOUT_IDX ? rnd(55,75) : rnd(12,140);
      return { id:i, x:rnd(r,W-r), y:rnd(r,H-r), r, baseR:r, color:COLORS[i%COLORS.length], alpha:0, targetAlpha:0, label:LABELS[i], vx:rnd(-0.18,0.18), vy:rnd(-0.18,0.18), delay:i*40, born:performance.now(), phase:rnd(0,Math.PI*2) };
    }

    let circles: Circle[] = Array.from({length:41},(_,i)=>createCircle(i));
    let hoveredCircle: Circle | null = null;

    function dist(ax: number, ay: number, bx: number, by: number){ return Math.sqrt((ax-bx)**2+(ay-by)**2); }

    function draw(now: number){
      ctx.clearRect(0,0,W,H);
      ctx.strokeStyle='rgba(240,237,232,0.025)'; ctx.lineWidth=1;
      for(let x=0;x<W;x+=80){ ctx.beginPath();ctx.moveTo(x,0);ctx.lineTo(x,H);ctx.stroke(); }
      for(let y=0;y<H;y+=80){ ctx.beginPath();ctx.moveTo(0,y);ctx.lineTo(W,y);ctx.stroke(); }
      hoveredCircle = null;
      circles.forEach(c=>{
        const age = now - c.born - c.delay;
        if(age<0) return;
        const eased = 1-Math.pow(1-Math.min(age/800,1),3);
        c.x+=c.vx; c.y+=c.vy;
        if(c.x-c.r<0||c.x+c.r>W) c.vx*=-1;
        if(c.y-c.r<0||c.y+c.r>H) c.vy*=-1;
        const isHovered = dist(mouse.x,mouse.y,c.x,c.y)<c.r;
        if(isHovered) hoveredCircle=c;
        if(isHovered && lastHoveredId !== c.id){ playNote(NOTES[c.id % NOTES.length]); lastHoveredId = c.id; }
        if(!isHovered && lastHoveredId === c.id) lastHoveredId = -1;
        canvas.style.cursor = (hoveredCircle?.label) ? 'pointer' : 'none';
        c.targetAlpha = isHovered?1:0;
        c.alpha += (c.targetAlpha-c.alpha)*0.08;
        const pulse = isHovered ? 1+0.06*Math.sin(now*0.004+c.phase) : 1;
        const displayR = c.baseR*eased*pulse;
        if(c.alpha>0.01){
          const glow=ctx.createRadialGradient(c.x,c.y,0,c.x,c.y,displayR*2.5);
          glow.addColorStop(0,c.color+Math.round(c.alpha*60).toString(16).padStart(2,'0'));
          glow.addColorStop(1,'transparent');
          ctx.beginPath();ctx.arc(c.x,c.y,displayR*2.5,0,Math.PI*2);
          ctx.fillStyle=glow;ctx.fill();
        }
        ctx.beginPath();ctx.arc(c.x,c.y,displayR,0,Math.PI*2);
        if(c.alpha>0.01){
          const fill=ctx.createRadialGradient(c.x,c.y-displayR*0.3,displayR*0.1,c.x,c.y,displayR);
          fill.addColorStop(0,c.color+'ff');fill.addColorStop(1,c.color+'99');
          ctx.fillStyle=fill;ctx.globalAlpha=c.alpha*eased;ctx.fill();ctx.globalAlpha=1;
        } else {
          ctx.strokeStyle=`rgba(240,237,232,${0.08*eased})`;ctx.lineWidth=1;ctx.stroke();
          if(c.label){
            const pulse = 0.5 + 0.5*Math.sin(now*0.0015 + c.phase);
            const glow2 = ctx.createRadialGradient(c.x,c.y,0,c.x,c.y,displayR*2);
            glow2.addColorStop(0, c.color+Math.round(pulse*40).toString(16).padStart(2,'0'));
            glow2.addColorStop(1,'transparent');
            ctx.beginPath();ctx.arc(c.x,c.y,displayR*2,0,Math.PI*2);
            ctx.fillStyle=glow2;ctx.fill();
          }
        }
        if(c.label && c.alpha > 0.3 && displayR > 20){
          ctx.globalAlpha = c.alpha * eased;
          ctx.fillStyle = '#080810';
          ctx.font = `bold ${Math.max(10, displayR*0.28)}px 'DM Mono',monospace`;
          ctx.textAlign = 'center'; ctx.textBaseline = 'middle';
          ctx.fillText(c.label, c.x, c.y);
          ctx.globalAlpha = 1;
        }
      });
      requestAnimationFrame(draw);
    }

    const isMobile = window.matchMedia('(max-width: 768px)').matches;
    if (isMobile) { document.getElementById('hint')!.textContent = 'tap the circles'; }
    window.addEventListener('mousemove',e=>{ mouse.x=e.clientX;mouse.y=e.clientY; });
    canvas.addEventListener('click', () => {
      if(hoveredCircle?.label && SECTIONS[hoveredCircle.label]) SECTIONS[hoveredCircle.label]();
    });
    canvas.addEventListener('touchend', e => {
      const t = e.changedTouches[0];
      const hit = circles.find(c => dist(t.clientX, t.clientY, c.x, c.y) < c.r && c.label);
      if(hit && SECTIONS[hit.label]) SECTIONS[hit.label]();
    }, {passive:true});
    window.addEventListener('touchstart',e=>{ const t=e.touches[0]; mouse.x=t.clientX; mouse.y=t.clientY; }, {passive:true});
    window.addEventListener('touchmove',e=>{ const t=e.touches[0]; mouse.x=t.clientX; mouse.y=t.clientY; }, {passive:true});
    window.addEventListener('touchend',()=>{ mouse.x=-999; mouse.y=-999; }, {passive:true});
    window.addEventListener('resize',()=>{ W=canvas.width=window.innerWidth;H=canvas.height=window.innerHeight;circles=Array.from({length:41},(_,i)=>createCircle(i)); });
    requestAnimationFrame(draw);
  </script>
</Layout>
