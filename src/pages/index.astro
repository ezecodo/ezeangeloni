---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Eze Angeloni">
  <Fragment slot="head">
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;700;800&family=DM+Mono:ital@0;1&family=Cormorant+Garamond:wght@300;400&display=swap" rel="stylesheet" />
    <style>
      *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
      :root {
        --bg: #080810; --text: #f0ede8; --muted: rgba(240,237,232,0.3);
      }
      html, body { width: 100%; height: 100%; overflow: hidden; background: var(--bg); color: var(--text); font-family: 'Syne', sans-serif; cursor: none; }
      canvas { position: fixed; inset: 0; width: 100%; height: 100%; will-change: transform; }
      #cursor { position: fixed; width: 5px; height: 5px; background: var(--text); border-radius: 50%; pointer-events: none; z-index: 9999; transform: translate(-50%,-50%); }
      #cursor::before, #cursor::after { content:''; position:absolute; border-radius:50%; border:1px solid rgba(240,237,232,0.5); top:50%; left:50%; transform:translate(-50%,-50%); animation: sonar 2.4s ease-out infinite; }
      #cursor::after { animation-delay:1.2s; }
      #cursor.on-bubble::before, #cursor.on-bubble::after { border-color: rgba(110,249,245,0.8); animation-duration:1.2s; }
      @keyframes sonar { 0% { width:5px; height:5px; opacity:.8; } 100% { width:70px; height:70px; opacity:0; } }
      #hero { position: fixed; inset: 0; display: flex; flex-direction: column; align-items: center; justify-content: flex-start; padding-top: 4vh; text-align: center; pointer-events: none; z-index: 10; gap: 8px; }
      #hero h1 { font-size: clamp(3rem,8vw,7rem); font-weight: 800; letter-spacing: -0.03em; opacity: 0; animation: fadeUp 1.2s cubic-bezier(.16,1,.3,1) .3s forwards; }
      #hero p { font-family: 'DM Mono', monospace; font-size: clamp(.7rem,1.5vw,.95rem); letter-spacing: .25em; text-transform: uppercase; color: var(--muted); opacity: 0; animation: fadeUp 1.2s cubic-bezier(.16,1,.3,1) .6s forwards; }
      #hint { position: fixed; bottom: 2rem; left: 50%; transform: translateX(-50%); font-family: 'DM Mono', monospace; font-size: .7rem; letter-spacing: .2em; color: var(--muted); text-transform: uppercase; z-index: 10; pointer-events: none; opacity: 0; animation: fadeUp 1s ease 1.5s forwards; }
      #modal-overlay { position: fixed; inset: 0; background: rgba(8,8,16,0.85); backdrop-filter: blur(12px); z-index: 100; display: flex; align-items: center; justify-content: center; opacity: 0; pointer-events: none; transition: opacity .4s ease; }
      #modal-overlay.open { opacity: 1; pointer-events: all; }
      #modal { background: rgba(240,237,232,0.04); border: 1px solid rgba(240,237,232,0.1); border-radius: 16px; padding: 3rem; max-width: 680px; width: 90%; max-height: 80vh; overflow-y: auto; position: relative; transform: translateY(30px); transition: transform .4s cubic-bezier(.16,1,.3,1); }
      #modal-overlay.open #modal { transform: translateY(0); }
      #modal h2 { font-family: 'Cormorant Garamond', serif; font-size: clamp(2rem,5vw,3.5rem); font-weight: 300; letter-spacing: .3em; text-transform: uppercase; margin-bottom: 1.5rem; }
      #modal p { font-family: 'DM Mono', monospace; font-size: .85rem; line-height: 1.9; color: rgba(240,237,232,0.85); }
      #modal-close { position: absolute; top: 1.2rem; right: 1.5rem; background: none; border: none; color: var(--muted); font-size: 1.5rem; cursor: pointer; line-height: 1; transition: color .2s; }
      #modal-close:hover { color: var(--text); }
      #msg-overlay { position: fixed; inset: 0; background: rgba(8,8,16,0.85); backdrop-filter: blur(12px); z-index: 100; display: flex; align-items: center; justify-content: center; opacity: 0; pointer-events: none; transition: opacity .4s ease; }
      #msg-overlay.open { opacity: 1; pointer-events: all; }
      #msg-box { background: rgba(240,237,232,0.04); border: 1px solid rgba(240,237,232,0.1); border-radius: 16px; padding: 2.5rem; max-width: 520px; width: 90%; position: relative; transform: translateY(30px); transition: transform .4s cubic-bezier(.16,1,.3,1); }
      #msg-overlay.open #msg-box { transform: translateY(0); }
      #msg-box h2 { font-family: 'Cormorant Garamond', serif; font-size: clamp(1.8rem,4vw,2.8rem); font-weight: 300; letter-spacing: .3em; text-transform: uppercase; margin-bottom: .5rem; }
      #msg-box .subtitle { font-family: 'DM Mono', monospace; font-size: .72rem; color: var(--muted); letter-spacing: .15em; margin-bottom: 1.8rem; }
      #msg-input { width: 100%; background: rgba(240,237,232,0.06); border: 1px solid rgba(240,237,232,0.15); border-radius: 8px; color: var(--text); font-family: 'DM Mono', monospace; font-size: .9rem; padding: .9rem 1rem; resize: none; outline: none; transition: border-color .2s; line-height: 1.7; }
      #msg-input:focus { border-color: rgba(240,237,232,0.4); }
      #msg-footer { display: flex; justify-content: space-between; align-items: center; margin-top: 1rem; }
      #word-count { font-family: 'DM Mono', monospace; font-size: .72rem; color: var(--muted); }
      #word-count.full { color: #b8f75b; }
      #word-count.over { color: #ff3f3f; }
      #msg-send { background: rgba(240,237,232,0.08); border: 1px solid rgba(240,237,232,0.2); color: var(--text); font-family: 'DM Mono', monospace; font-size: .75rem; letter-spacing: .15em; text-transform: uppercase; padding: .6rem 1.4rem; border-radius: 6px; cursor: pointer; transition: background .2s, border-color .2s; }
      #msg-send:hover { background: rgba(240,237,232,0.15); border-color: rgba(240,237,232,0.4); }
      #msg-send:disabled { opacity: .3; cursor: default; }
      #msg-close { position: absolute; top: 1.2rem; right: 1.5rem; background: none; border: none; color: var(--muted); font-size: 1.5rem; cursor: pointer; transition: color .2s; }
      #msg-close:hover { color: var(--text); }
      #img-overlay { position: fixed; inset: 0; background: rgba(8,8,16,0.92); backdrop-filter: blur(16px); z-index: 100; display: flex; align-items: center; justify-content: center; opacity: 0; pointer-events: none; transition: opacity .3s ease; cursor: pointer; }
      #img-overlay.open { opacity: 1; pointer-events: all; }
      #img-overlay img { max-width: 90vw; max-height: 85vh; border-radius: 8px; object-fit: contain; transform: scale(0.92); transition: transform .4s cubic-bezier(.16,1,.3,1); box-shadow: 0 0 60px rgba(0,0,0,0.6); }
      #img-overlay.open img { transform: scale(1); }
      #img-close { position: fixed; top: 1.5rem; right: 1.5rem; background: none; border: none; color: rgba(240,237,232,0.5); font-size: 1.5rem; cursor: pointer; z-index: 101; transition: color .2s; }
      #img-close:hover { color: var(--text); }
      #msg-thanks { text-align: center; padding: 1rem 0; }
      #msg-thanks p { font-family: 'Cormorant Garamond', serif; font-size: 1.6rem; font-weight: 300; letter-spacing: .2em; margin-bottom: .8rem; }
      #msg-thanks small { font-family: 'DM Mono', monospace; font-size: .72rem; color: var(--muted); letter-spacing: .1em; }
      @keyframes fadeUp { from { opacity:0; transform:translateY(20px); } to { opacity:1; transform:translateY(0); } }
      @keyframes logoGlow {
        0%   { filter: brightness(0) invert(1) drop-shadow(0 0 0px transparent); }
        15%  { filter: brightness(0) invert(1) drop-shadow(0 0 18px #6ef9f5) drop-shadow(0 0 40px #6ef9f580); }
        30%  { filter: brightness(0) invert(1) drop-shadow(0 0 18px #c77dff) drop-shadow(0 0 40px #c77dff80); }
        50%  { filter: brightness(0) invert(1) drop-shadow(0 0 18px #ff6eb4) drop-shadow(0 0 40px #ff6eb480); }
        65%  { filter: brightness(0) invert(1) drop-shadow(0 0 18px #b8f75b) drop-shadow(0 0 40px #b8f75b80); }
        80%  { filter: brightness(0) invert(1) drop-shadow(0 0 18px #ff9f1c) drop-shadow(0 0 40px #ff9f1c80); }
        100% { filter: brightness(0) invert(1) drop-shadow(0 0 0px transparent); }
      }
      #logo { width: clamp(16rem,40vw,30rem); margin-bottom: -8rem; filter: brightness(0) invert(1); animation: fadeUp 1.2s cubic-bezier(.16,1,.3,1) .3s forwards, logoGlow 6s ease-in-out 1.5s infinite; opacity: 0; }
      @media (max-width: 768px) {
        html, body { cursor: auto; }
        #cursor, #cursor::before, #cursor::after { display: none; }
        #hero { justify-content: center; padding-top: 0; gap: 4px; }
        #logo { width: 72vw; margin-bottom: -5rem; }
        #hero p { font-size: clamp(.75rem,4vw,1rem); letter-spacing: .2em; }
        #hint { font-size: .6rem; bottom: 1.5rem; }
      }
    </style>
  </Fragment>

  <div id="cursor"></div>
  <canvas id="canvas"></canvas>
  <div id="hero">
    <img id="logo" src="/eZe.svg" alt="eZe" />
    <p style="font-family: 'Cormorant Garamond', serif; font-size: clamp(1.2rem,3.5vw,2.4rem); font-weight: 300; letter-spacing: .5em; text-transform: uppercase; color: var(--text); opacity: 0; animation: fadeUp 1.2s cubic-bezier(.16,1,.3,1) .5s forwards; padding-left: .5em;">angeloni</p>
    <p>Developer · Builder · Explorer</p>
  </div>
  <div id="hint">explore the circles</div>

  <div id="msg-overlay">
    <div id="msg-box">
      <button id="msg-close">✕</button>
      <div id="msg-form">
        <h2>Leave a word</h2>
        <p class="subtitle">exactly 11 words. make them count.</p>
        <textarea id="msg-input" rows="3" placeholder="eleven words, no more, no less..."></textarea>
        <div id="msg-footer">
          <span id="word-count">0 / 11</span>
          <button id="msg-send" disabled>send</button>
        </div>
      </div>
      <div id="msg-thanks" style="display:none">
        <p>thank you ✦</p>
        <small>your words are now part of this space</small>
      </div>
    </div>
  </div>

  <div id="img-overlay">
    <button id="img-close">✕</button>
    <img id="img-full" src="" alt="" />
  </div>

  <div id="modal-overlay">
    <div id="modal">
      <button id="modal-close">✕</button>
      <h2>About</h2>
      <p>Hey, I'm Eze. I build things for the web — from the database to the pixel.</p>
      <p style="margin-top:1.2rem">Originally from Argentina, now based in Barcelona, I've spent years at the intersection of technology and culture. I've helped organize theatre festivals, been part of interdisciplinary collectives, and worked on projects that use culture as a bridge between societies. That background shapes how I approach every line of code — with purpose, context, and people in mind.</p>
      <p style="margin-top:1.2rem">On the technical side, I'm a full-stack developer working with Next.js, React, and Node — building editorial platforms, CMS systems, and interactive experiences.</p>
      <p style="margin-top:1.2rem">Currently available for freelance work. If you've got something interesting brewing, I'd love to hear about it.</p>
    </div>
  </div>

  <script>
    const canvas = document.getElementById('canvas') as HTMLCanvasElement;
    const ctx = canvas.getContext('2d')!;
    const cursor = document.getElementById('cursor')!;

    let W = canvas.width = window.innerWidth;
    let H = canvas.height = window.innerHeight;
    let mouse = { x: -999, y: -999 };
    const COLORS = ['#ff3f3f','#ff9f1c','#6ef9f5','#b8f75b','#c77dff','#ff6eb4','#38bdf8','#ffd166'];
    const NOTES =  [392, 440, 523, 587, 659, 349, 466, 311];
    let audioCtx: AudioContext | null = null;
    let masterGain: GainNode | null = null;
    let lastSoundTime = 0;
    const SOUND_COOLDOWN = 180;
    function playNote(freq: number) {
      const now = performance.now();
      if (now - lastSoundTime < SOUND_COOLDOWN) return;
      lastSoundTime = now;
      if (!audioCtx) { audioCtx = new AudioContext(); masterGain = audioCtx.createGain(); masterGain.gain.value = 0.18; masterGain.connect(audioCtx.destination); }
      const t = audioCtx.currentTime;
      function layer(f: number, type: OscillatorType, vol: number, dur: number, pitchDrop = 1){
        const osc = audioCtx!.createOscillator();
        const g = audioCtx!.createGain();
        osc.connect(g); g.connect(masterGain!);
        osc.type = type;
        osc.frequency.setValueAtTime(f, t);
        if(pitchDrop !== 1) osc.frequency.exponentialRampToValueAtTime(f * pitchDrop, t + dur * 0.6);
        g.gain.setValueAtTime(vol, t);
        g.gain.exponentialRampToValueAtTime(0.001, t + dur);
        osc.start(t); osc.stop(t + dur);
      }
      layer(freq,     'sine',     1.0,  0.35, 0.75); // main — suave con pitch drop
      layer(freq/2,   'triangle', 0.5,  0.18);        // bass — cuerpo, corto
      layer(freq*2,   'sine',     0.15, 0.2);         // shimmer — brillo suave
    }
    let songPlaying = false;
    // Note frequencies
    const G4=392, A4=440, B4=493.88, C5=523.25, D5=587.33, E4=329.63, D4=293.66, C4=261.63;
    // [freq, duration_seconds] — 0 = rest
    const REDEMPTION: [number,number][] = [
      // "Old pi-rates, yes, they rob I"
      [G4,.4],[B4,.4],[A4,.3],[G4,.3],[E4,.4],[D4,.3],[E4,.3],[G4,.7],
      // "Sold I to the mer-chant ships"
      [G4,.4],[B4,.4],[A4,.3],[G4,.3],[E4,.4],[D4,.3],[C4,.3],[D4,.7],
      // "Mi-nutes af-ter they took I"
      [E4,.4],[D4,.3],[E4,.3],[G4,.4],[E4,.3],[D4,.7],
      // "From the bot-tom-less pit"
      [G4,.4],[B4,.4],[A4,.3],[G4,.3],[E4,.8],
      [0,.5],
      // "Won't you help to sing"
      [G4,.4],[G4,.25],[A4,.25],[B4,.4],[A4,.3],[G4,.7],
      // "These songs of free-dom"
      [G4,.4],[A4,.3],[B4,.4],[A4,.3],[G4,.3],[E4,.7],
      // "'Cause all I ev-er had"
      [G4,.4],[G4,.25],[A4,.25],[B4,.4],[A4,.3],[G4,.3],[E4,.3],[D4,.5],
      // "Re-demp-tion songs"
      [G4,.4],[B4,.4],[D5,.4],[C5,.3],[B4,.9],
      [0,.3],
      // "Re-demp-tion songs" (repeat, hold)
      [G4,.4],[B4,.4],[D5,.4],[C5,.3],[B4,1.4],
    ];
    async function playSong(){
      if(songPlaying) return;
      songPlaying = true;
      if(!audioCtx){ audioCtx = new AudioContext(); masterGain = audioCtx.createGain(); masterGain.gain.value = 0.18; masterGain.connect(audioCtx.destination); }
      for(const [freq, dur] of REDEMPTION){
        if(!songPlaying) break;
        if(freq > 0){
          const osc = audioCtx.createOscillator();
          const g = audioCtx.createGain();
          osc.connect(g); g.connect(masterGain!);
          osc.type = 'triangle';
          osc.frequency.value = freq;
          g.gain.setValueAtTime(0.9, audioCtx.currentTime);
          g.gain.exponentialRampToValueAtTime(0.001, audioCtx.currentTime + dur * 0.85);
          osc.start(); osc.stop(audioCtx.currentTime + dur);
        }
        await new Promise(r => setTimeout(r, dur * 1000));
      }
      songPlaying = false;
    }
    document.addEventListener('keydown', e => { if(e.key === '1') playSong(); });
    const imgOverlay = document.getElementById('img-overlay')!;
    const imgFull = document.getElementById('img-full') as HTMLImageElement;
    document.getElementById('img-close')!.addEventListener('click', closeImgModal);
    imgOverlay.addEventListener('click', e => { if(e.target === imgOverlay) closeImgModal(); });
    function openImgModal(src: string){ imgFull.src = src; imgOverlay.classList.add('open'); }
    function closeImgModal(){ imgOverlay.classList.remove('open'); setTimeout(()=>{ imgFull.src=''; }, 300); }

    const SECTIONS: Record<string, () => void> = {
      about: () => openModal(),
      message: () => openMsgModal()
    };
    const modal = document.getElementById('modal-overlay')!;
    document.getElementById('modal-close')!.addEventListener('click', closeModal);
    modal.addEventListener('click', e => { if(e.target === modal) closeModal(); });
    document.addEventListener('keydown', e => { if(e.key === 'Escape') closeModal(); });
    function openModal(){ modal.classList.add('open'); }
    function closeModal(){ modal.classList.remove('open'); }
    const ABOUT_IDX = 3;
    const MSG_IDX = 15;
    const LABELS: string[] = Array.from({length:41}, (_,i) => i === ABOUT_IDX ? 'about' : i === MSG_IDX ? 'message' : '');

    // Load frases from JSON — handles text and images
    const IMAGES = new Map<number, HTMLImageElement>();
    fetch('/frases.json')
      .then(r => r.json())
      .then(data => {
        const spareIdxs = LABELS.map((l,i) => l === '' ? i : -1).filter(i => i !== -1);
        let si = 0;
        data.frases.forEach((f: {texto?: string, imagen?: string}) => {
          if(spareIdxs[si] === undefined) return;
          const idx = spareIdxs[si];
          if(f.imagen){
            LABELS[idx] = '__img__';
            const img = new Image();
            IMAGES.set(idx, img); // set immediately so hover works once loaded
            img.src = f.imagen;
          } else if(f.texto){
            LABELS[idx] = f.texto;
          }
          si++;
        });
        // resize image circles now that labels are known
        circles.forEach(c => {
          if(LABELS[c.id] === '__img__'){ c.r = 50; c.baseR = 50; }
        });
      })
      .catch(() => {});

    // Message modal
    const msgOverlay = document.getElementById('msg-overlay')!;
    const msgInput = document.getElementById('msg-input') as HTMLTextAreaElement;
    const wordCount = document.getElementById('word-count')!;
    const msgSend = document.getElementById('msg-send') as HTMLButtonElement;
    const msgForm = document.getElementById('msg-form')!;
    const msgThanks = document.getElementById('msg-thanks')!;

    function countWords(s: string){ return s.trim() === '' ? 0 : s.trim().split(/\s+/).length; }

    msgInput.addEventListener('input', () => {
      const words = msgInput.value.trim() === '' ? 0 : msgInput.value.trim().split(/\s+/).filter(w=>w.length>0).length;
      wordCount.textContent = `${words} / 11`;
      wordCount.className = words === 11 ? 'full' : words > 11 ? 'over' : '';
      msgSend.disabled = words !== 11;
    });

    msgSend.addEventListener('click', async () => {
      msgSend.disabled = true;
      msgSend.textContent = 'sending...';
      try {
        const res = await fetch('https://n8n.ezeangeloni.xyz/webhook/mensaje', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ mensaje: msgInput.value.trim() })
        });
        if(res.ok){
          msgForm.style.display = 'none';
          msgThanks.style.display = 'block';
          setTimeout(() => closeMsgModal(), 2800);
        } else {
          wordCount.textContent = 'something went wrong, try again';
        }
      } catch(e) {
        wordCount.textContent = 'connection error';
      }
      msgSend.textContent = 'send';
      msgSend.disabled = false;
    });

    function openMsgModal(){
      msgInput.value = ''; wordCount.textContent = '0 / 11'; wordCount.classList.remove('full');
      msgSend.disabled = true; msgForm.style.display = 'block'; msgThanks.style.display = 'none';
      msgOverlay.classList.add('open');
      setTimeout(() => msgInput.focus(), 400);
    }
    function closeMsgModal(){ msgOverlay.classList.remove('open'); }
    document.getElementById('msg-close')!.addEventListener('click', closeMsgModal);
    msgOverlay.addEventListener('click', e => { if(e.target === msgOverlay) closeMsgModal(); });
    document.addEventListener('keydown', e => { if(e.key === 'Escape'){ closeModal(); closeMsgModal(); closeImgModal(); } });
    function rnd(a: number, b: number){ return a + Math.random()*(b-a); }

    interface Circle {
      id: number; x: number; y: number; r: number; baseR: number;
      color: string; alpha: number; targetAlpha: number; label: string;
      vx: number; vy: number; delay: number; born: number; phase: number;
    }

    const isSafari = /^((?!chrome|android).)*safari/i.test(navigator.userAgent);
    const isMobileDevice = window.matchMedia('(max-width: 768px)').matches;
    const CIRCLE_COUNT = isSafari ? 28 : 41;

    function createCircle(i: number): Circle {
      const r = i === MSG_IDX
        ? rnd(isMobileDevice ? 16:22, isMobileDevice ? 24:32)
        : i === ABOUT_IDX
          ? rnd(isMobileDevice ? 36:55, isMobileDevice ? 50:75)
          : rnd(isMobileDevice ? 8:12, isMobileDevice ? 65:140);
      return { id:i, x:rnd(r,W-r), y:rnd(r,H-r), r, baseR:r, color:COLORS[i%COLORS.length], alpha:0, targetAlpha:0, label:LABELS[i], vx:rnd(-0.18,0.18), vy:rnd(-0.18,0.18), delay:i*40, born:performance.now(), phase:rnd(0,Math.PI*2) };
    }
    let circles: Circle[] = Array.from({length:CIRCLE_COUNT},(_,i)=>createCircle(i));
    let hoveredCircle: Circle | null = null;
    let prevUnderCursor = new Set<number>();

    // Cache grid on offscreen canvas
    let gridCanvas: HTMLCanvasElement | null = null;
    function buildGrid(){
      gridCanvas = document.createElement('canvas');
      gridCanvas.width = W; gridCanvas.height = H;
      const gc = gridCanvas.getContext('2d')!;
      gc.strokeStyle='rgba(240,237,232,0.025)'; gc.lineWidth=1;
      for(let x=0;x<W;x+=80){ gc.beginPath();gc.moveTo(x,0);gc.lineTo(x,H);gc.stroke(); }
      for(let y=0;y<H;y+=80){ gc.beginPath();gc.moveTo(0,y);gc.lineTo(W,y);gc.stroke(); }
    }
    buildGrid();

    function dist(ax: number, ay: number, bx: number, by: number){ return Math.sqrt((ax-bx)**2+(ay-by)**2); }

    function draw(now: number){
      ctx.clearRect(0,0,W,H);
      if(gridCanvas) ctx.drawImage(gridCanvas,0,0);
      hoveredCircle = null;
      // draw content bubbles last so they appear on top
      const sorted = [...circles].sort((a,b) => {
        const aHas = LABELS[a.id] ? 1 : 0;
        const bHas = LABELS[b.id] ? 1 : 0;
        return aHas - bHas;
      });
      // hover detection: topmost content bubble wins for click/visual
      const hoverSorted = [...sorted].reverse();
      const allUnderCursor = new Set<number>();
      hoverSorted.forEach(c => {
        const isHov = dist(mouse.x,mouse.y,c.x,c.y)<c.r;
        if(isHov){
          allUnderCursor.add(c.id);
          if(!hoveredCircle) hoveredCircle = c;
        }
      });
      // sound for every bubble the cursor just entered
      allUnderCursor.forEach(id => {
        if(!prevUnderCursor.has(id)) playNote(NOTES[id % NOTES.length]);
      });
      prevUnderCursor = allUnderCursor;
      sorted.forEach(c=>{
        const age = now - c.born - c.delay;
        if(age<0) return;
        const eased = 1-Math.pow(1-Math.min(age/800,1),3);
        c.x+=c.vx; c.y+=c.vy;
        if(c.x-c.r<0||c.x+c.r>W) c.vx*=-1;
        if(c.y-c.r<0||c.y+c.r>H) c.vy*=-1;
        const isHovered = hoveredCircle?.id === c.id;
        if(hoveredCircle && LABELS[hoveredCircle.id]) cursor.classList.add('on-bubble'); else cursor.classList.remove('on-bubble');
        canvas.style.cursor = 'none';
        c.targetAlpha = isHovered?1:0;
        c.alpha += (c.targetAlpha-c.alpha)*0.08;
        const isMsg = LABELS[c.id] === 'message';
        const pulse = isHovered
          ? (isMsg ? 2.8 + 0.08*Math.sin(now*0.003+c.phase) : 1+0.06*Math.sin(now*0.004+c.phase))
          : 1;
        const displayR = c.baseR*eased*pulse;
        if(c.alpha>0.01){
          if(!isSafari){
            const glow=ctx.createRadialGradient(c.x,c.y,0,c.x,c.y,displayR*2.5);
            glow.addColorStop(0,c.color+Math.round(c.alpha*60).toString(16).padStart(2,'0'));
            glow.addColorStop(1,'transparent');
            ctx.beginPath();ctx.arc(c.x,c.y,displayR*2.5,0,Math.PI*2);
            ctx.fillStyle=glow;ctx.fill();
          }
        }
        ctx.beginPath();ctx.arc(c.x,c.y,displayR,0,Math.PI*2);
        if(c.alpha>0.01){
          const bubbleColor = LABELS[c.id] === 'message' ? '#ffd166' : c.color;
          if(isSafari){
            ctx.fillStyle=bubbleColor;ctx.globalAlpha=c.alpha*eased*0.85;ctx.fill();ctx.globalAlpha=1;
          } else {
            const fill=ctx.createRadialGradient(c.x,c.y-displayR*0.3,displayR*0.1,c.x,c.y,displayR);
            fill.addColorStop(0,bubbleColor+'ff');fill.addColorStop(1,bubbleColor+'99');
            ctx.fillStyle=fill;ctx.globalAlpha=c.alpha*eased;ctx.fill();ctx.globalAlpha=1;
          }
        } else {
          ctx.strokeStyle=`rgba(240,237,232,${0.08*eased})`;ctx.lineWidth=1;ctx.stroke();
          if(LABELS[c.id] || IMAGES.has(c.id)){
            const pulse = 0.5 + 0.5*Math.sin(now*0.0015 + c.phase);
            const isImgBubble = LABELS[c.id]==='__img__';
            const glowColor = isMsg ? '#ffd166' : isImgBubble ? '#38bdf8' : c.color;
            const glowAlpha = isImgBubble ? pulse*120 : pulse*50;
            if(!isSafari){
              const glow2 = ctx.createRadialGradient(c.x,c.y,0,c.x,c.y,displayR*2.5);
              glow2.addColorStop(0, glowColor+Math.round(glowAlpha).toString(16).padStart(2,'0'));
              glow2.addColorStop(1,'transparent');
              ctx.beginPath();ctx.arc(c.x,c.y,displayR*2.5,0,Math.PI*2);
              ctx.fillStyle=glow2;ctx.fill();
            } else {
              ctx.beginPath();ctx.arc(c.x,c.y,displayR*1.8,0,Math.PI*2);
              ctx.fillStyle=glowColor;ctx.globalAlpha=(isImgBubble?0.28:0.12)*pulse*eased;ctx.fill();ctx.globalAlpha=1;
            }
            // photo icon on image bubble
            if(isImgBubble){
              ctx.globalAlpha = pulse * 0.7 * eased;
              ctx.fillStyle = '#38bdf8';
              ctx.font = `${Math.max(12,displayR*0.45)}px serif`;
              ctx.textAlign='center'; ctx.textBaseline='middle';
              ctx.fillText('◎', c.x, c.y);
              ctx.globalAlpha = 1;
            }
            if(isMsg){
              const hovered = c.alpha > 0.5;
              const rot = now * 0.0003;
              const breath = 0.5 + 0.5*Math.sin(now*0.0012 + c.phase);
              ctx.save();
              ctx.translate(c.x, c.y);
              ctx.rotate(rot);

              // corona rings
              for(let ring=3;ring>0;ring--){
                const ringR = displayR*(1.4 + ring*0.45 + breath*0.2);
                const ringAlpha = (hovered ? 0.12 : 0.06) * (4-ring) * eased;
                ctx.beginPath(); ctx.arc(0,0,ringR,0,Math.PI*2);
                ctx.fillStyle = `rgba(255,200,50,${ringAlpha})`; ctx.fill();
              }

              // alternating long/short rays (24 total)
              const numRays = 24;
              for(let ri=0;ri<numRays;ri++){
                const angle = (ri/numRays)*Math.PI*2;
                const isLong = ri % 2 === 0;
                const breathe = Math.sin(now*0.0018 + ri*0.6);
                const inner = displayR + 4;
                const rayLen = isLong
                  ? displayR*(hovered ? 2.8 + 0.7*breathe : 1.6 + 0.35*breathe)
                  : displayR*(hovered ? 1.4 + 0.4*breathe : 0.7 + 0.2*breathe);
                const outer = inner + rayLen;
                const halfW = isLong ? (hovered ? 2.8 : 2) : (hovered ? 1.8 : 1.2);
                const px = Math.cos(angle), py = Math.sin(angle);
                const nx = -py, ny = px;
                const alpha = (hovered ? 0.75 : 0.4) * (isLong ? 1 : 0.6) * eased;
                ctx.beginPath();
                ctx.moveTo(px*inner + nx*halfW, py*inner + ny*halfW);
                ctx.lineTo(px*outer, py*outer);
                ctx.lineTo(px*inner - nx*halfW, py*inner - ny*halfW);
                ctx.closePath();
                ctx.fillStyle = `rgba(255,${isLong?215:235},${isLong?60:100},${alpha})`;
                ctx.fill();
              }

              // bright inner core
              ctx.beginPath(); ctx.arc(0,0,displayR*0.45,0,Math.PI*2);
              ctx.fillStyle = `rgba(255,245,180,${(hovered?0.6:0.3)*eased})`; ctx.fill();

              ctx.restore();
            }
          }
        }
        const label = LABELS[c.id] || '';
        const isImg = label === '__img__';
        const isNav = label === 'about' || label === 'message';
        // image bubble — draw clipped photo when hovered
        if(isImg && c.alpha > 0.3){
          const img = IMAGES.get(c.id);
          if(img && img.complete && img.naturalWidth > 0){
            ctx.save();
            ctx.globalAlpha = c.alpha * eased;
            ctx.beginPath(); ctx.arc(c.x, c.y, displayR, 0, Math.PI*2); ctx.clip();
            const s = displayR * 2;
            ctx.drawImage(img, c.x - displayR, c.y - displayR, s, s);
            ctx.restore();
          }
        }
        if(label && !isImg && c.alpha > 0.3){
          ctx.globalAlpha = c.alpha * eased;
          if(isNav && displayR > 20){
            // about & message: text inside bubble
            ctx.fillStyle = '#080810';
            ctx.font = `bold ${Math.max(10, displayR*0.28)}px 'DM Mono',monospace`;
            ctx.textAlign = 'center'; ctx.textBaseline = 'middle';
            ctx.fillText(label, c.x, c.y);
          } else if(!isNav){
            // frases: large elegant text below bubble, wrapped
            const fontSize = Math.max(22, Math.min(32, W * 0.025));
            ctx.fillStyle = '#f0ede8';
            ctx.font = `300 italic ${fontSize}px 'Cormorant Garamond',serif`;
            ctx.textAlign = 'center'; ctx.textBaseline = 'top';
            const maxWidth = Math.min(420, W * 0.75);
            const words = label.split(' ');
            const lines: string[] = [];
            let line = '';
            for(const word of words){
              const test = line ? line + ' ' + word : word;
              if(ctx.measureText(test).width > maxWidth && line){ lines.push(line); line = word; }
              else line = test;
            }
            if(line) lines.push(line);
            const lineH = fontSize * 1.35;
            const startY = c.y + displayR + 16;
            lines.forEach((l, i) => {
              ctx.globalAlpha = c.alpha * eased;
              ctx.fillText(l, c.x, startY + i * lineH);
            });
            ctx.globalAlpha = 1;
          }
          ctx.globalAlpha = 1;
        }
      });
      requestAnimationFrame(draw);
    }


    if (isMobileDevice) { document.getElementById('hint')!.textContent = 'tap the circles'; }
    window.addEventListener('mousemove',e=>{ mouse.x=e.clientX;mouse.y=e.clientY; (cursor as HTMLElement).style.left=e.clientX+'px'; (cursor as HTMLElement).style.top=e.clientY+'px'; });
    canvas.addEventListener('click', () => {
      if(!hoveredCircle) return;
      const lbl = LABELS[hoveredCircle.id];
      if(lbl === '__img__'){
        const img = IMAGES.get(hoveredCircle.id);
        if(img?.src) openImgModal(img.src);
      } else if(lbl && SECTIONS[lbl]){
        SECTIONS[lbl]();
      }
    });
    canvas.addEventListener('touchend', e => {
      const t = e.changedTouches[0];
      // same priority as draw: content bubbles win over empty ones
      const hits = circles.filter(c => dist(t.clientX, t.clientY, c.x, c.y) < c.r);
      const hit = hits.find(c => LABELS[c.id]) ?? hits[0];
      if(!hit) return;
      const lbl = LABELS[hit.id];
      if(lbl === '__img__'){
        const img = IMAGES.get(hit.id);
        if(img?.src) openImgModal(img.src);
      } else if(lbl && SECTIONS[lbl]){
        SECTIONS[lbl]();
      }
    }, {passive:true});
    window.addEventListener('touchstart',e=>{ const t=e.touches[0]; mouse.x=t.clientX; mouse.y=t.clientY; }, {passive:true});
    window.addEventListener('touchmove',e=>{ const t=e.touches[0]; mouse.x=t.clientX; mouse.y=t.clientY; }, {passive:true});
    window.addEventListener('touchend',()=>{ mouse.x=-999; mouse.y=-999; }, {passive:true});
    window.addEventListener('resize',()=>{ W=canvas.width=window.innerWidth;H=canvas.height=window.innerHeight; buildGrid(); circles=Array.from({length:CIRCLE_COUNT},(_,i)=>createCircle(i)); });
    requestAnimationFrame(draw);
  </script>
</Layout>